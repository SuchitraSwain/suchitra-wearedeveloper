{
  "name": "wearedevelopers-presentation",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:preview": "npm run build && firebase hosting:channel:deploy preview --expires 7d",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "audit:responsive": "node scripts/responsive-audit.mjs",
    "audit:portfolio": "node scripts/responsive-audit-portfolio.mjs",
    "record:demo": "node scripts/record-demo.mjs",
    "record:emulate": "node scripts/record-emulate-demo.mjs",
    "record:emulate-devices": "node scripts/record-emulate-devices-demo.mjs",
    "record:evolution": "node scripts/record-evolution-demo.mjs",
    "record:debug-evolution": "node scripts/record-debug-evolution-demo.mjs",
    "record:performance": "node scripts/record-mcp-feature-demo.mjs performance",
    "record:network": "node scripts/record-mcp-feature-demo.mjs network",
    "record:debugging": "node scripts/record-mcp-feature-demo.mjs debugging"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "playwright": "^1.52.0",
    "firebase-tools": "^15.22.4",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "vite": "^8"
  }
}
